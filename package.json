{
  "name": "insanesoccer",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "build": "webpack --config webpack.config.prod.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "minify-css": "npx minify public/css/style.css > public/css/style.min.css",
    "start-local": "npm-run-all --parallel watch:build watch:server --print-label",
    "watch:server": "npx http-server -d false -o -s -c-1",
    "watch:build": "webpack -w",
    "watch:typecheck": "tsc --noEmit --watch --pretty",
    "watch:lint": "nodemon --watch src --ext ts --exec \"eslint src --ext .ts\" --quiet"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "http-server": "^14.1.1",
    "minify": "^15.3.1",
    "nodemon": "^3.1.14",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "ts-loader": "^9.6.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3"
  },
  "dependencies": {
    "ts-bus": "^2.3.1"
  }
}
